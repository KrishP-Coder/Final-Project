import random
def final_project():
  play = "yes"
  while play == "yes":
    print("\nChoose difficulty: easy/medium/hard")
    difficulty = input("Enter difficulty: ")
    if difficulty == "easy":
      maximum_num = 50
    elif difficulty == "medium":
      maximum_num = 100
    elif difficulty == "hard":
      maximum_num = 200
    else:
      print("Invalid Difficulty")

    target_num = random.randint(1, maximum_num)
    attempt_count = 0
    attempt_record = []
    guess = None
    maximum_attempts = 10

    while guess != target_num and attempt_count < max_attempts: 
      guess = input("Enter your guess: ")
      if guess.isdigit():
        guess = int(guess)
        attempt_count += 1
        attempt_record.append(guess)

        if guess > target_num:
          print("Too high!")
        elif guess < target_num:
          print("Too low!")
        else:
          print("Congratulations! You got it in", attempt_count, "attempts.")
          print("Your guesses:", attempt_record)
      else:
        print("Enter a valid number")

    if guess != target_num:
      print("You're all out of attempts! The number was", target_num)
      print("Your guesses:", attempt_record)

    play = input("Play again? yes/no: ")
  
